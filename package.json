{
  "name": "@feod/analyzer",
  "version": "0.1.0",
  "type": "module",
  "description": "FEOD architecture analyzer CLI with JSON and React report output",
  "license": "MIT",
  "author": "FEOD Architecture",
  "homepage": "https://github.com/feod-architecture/feod-analyzer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feod-architecture/feod-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/feod-architecture/feod-analyzer/issues"
  },
  "workspaces": [
    "web"
  ],
  "bin": {
    "feod-analyzer": "index.js"
  },
  "files": [
    "bin",
    "web/dist",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:web": "node scripts/run-web-script.mjs build",
    "build:cli": "go build -o bin/feod-analyzer ./cmd/feod-analyzer",
    "build": "node scripts/run-web-script.mjs build && go build -o bin/feod-analyzer ./cmd/feod-analyzer",
    "test:go": "go test ./...",
    "test:web": "node scripts/run-web-script.mjs build",
    "test": "go test ./... && node scripts/run-web-script.mjs build",
    "prepack": "node scripts/run-web-script.mjs build && go build -o bin/feod-analyzer ./cmd/feod-analyzer"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "feod",
    "architecture",
    "analyzer",
    "dependencies"
  ],
  "engines": {
    "node": ">=20"
  }
}
